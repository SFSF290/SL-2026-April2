def load_sample_data(sample, tissue):
    file_path = os.path.join(merged_dir, f"{sample}_{tissue}_combined.csv")
    if os.path.exists(file_path):
        return pd.read_csv(file_path)
    return pd.DataFrame()

def deduplicate_cnvs(df, window=1000):
    """Deduplicate CNVs within 1000 bp (same chr, svtype, cn_state)"""
    if df.empty:
        return df
    df = df[df['Chr_Number'].notna()].copy()
    df = df.sort_values(['Chr_Number', 'Start']).reset_index(drop=True)
    deduplicated = []
    used_indices = set()
    for idx, cnv in df.iterrows():
        if idx in used_indices:
            continue
        matches = []
        for idx2, cnv2 in df.iterrows():
            if idx2 <= idx or idx2 in used_indices:
                continue
            if (cnv['Chr_Number'] == cnv2['Chr_Number'] and
                cnv['SVTYPE'] == cnv2['SVTYPE'] and
                cnv['CN_State'] == cnv2['CN_State'] and
                abs(cnv['Start'] - cnv2['Start']) <= window and
                abs(cnv['End'] - cnv2['End']) <= window):
                matches.append(idx2)
        if matches:
            all_indices = [idx] + matches
            merged_cnv = cnv.copy()
            if 'Source' in df.columns:
                sources = [df.loc[i, 'Source'] for i in all_indices]
                merged_cnv['Source'] = ';'.join(sorted(set(sources)))
            starts = [df.loc[i, 'Start'] for i in all_indices]
            ends = [df.loc[i, 'End'] for i in all_indices]
            merged_cnv['Start'] = int(pd.Series(starts).median())
            merged_cnv['End'] = int(pd.Series(ends).median())
            merged_cnv['Deduplicated_Count'] = len(all_indices)
            deduplicated.append(merged_cnv)
            used_indices.update(all_indices)
        else:
            cnv_copy = cnv.copy()
            cnv_copy['Deduplicated_Count'] = 1
            deduplicated.append(cnv_copy)
            used_indices.add(idx)
    return pd.DataFrame(deduplicated).reset_index(drop=True)

def within_1000bp_match(cnv, parent_df, window=1000):
    if parent_df.empty or pd.isna(cnv['Chr_Number']):
        return False
    matches = parent_df[
        (parent_df['Chr_Number'] == cnv['Chr_Number']) &
        (parent_df['SVTYPE'] == cnv['SVTYPE']) &
        (parent_df['CN_State'] == cnv['CN_State']) &
        (abs(parent_df['Start'] - cnv['Start']) <= window) &
        (abs(parent_df['End'] - cnv['End']) <= window)
    ]
    return len(matches) > 0

